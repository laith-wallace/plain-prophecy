h Scripture, history, and the Reformation tradition."}],["$","meta","18",{"name":"twitter:image","content":"https://plainprophecy.com/og/og-default.png"}],["$","link","19",{"rel":"icon","href":"/favicon.ico","type":"image/x-icon","sizes":"16x16"}]]
